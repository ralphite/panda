{
  "manifest_version": 3,
  "name": "Panda Screenshot",
  "version": "0.1.0",
  "description": "Capture a full page screenshot, crop it, and upload it to Panda.",
  "action": {
    "default_title": "Capture with Panda"
  },
  "commands": {
    "take-screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "MacCtrl+Shift+P"
      },
      "description": "Capture with Panda"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "alarms", "contextMenus", "scripting", "storage", "tabs"],
  "host_permissions": ["http://localhost:8088/*", "<all_urls>"]
}
